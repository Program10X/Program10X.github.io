<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Program10X | Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #020204; color: #ffffff; height: 100vh; display: flex; overflow: hidden; position: relative; }
        
        /* 🟩 HIGH-DENSITY GLOWING MATRIX BACKGROUND */
        #coderRain { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 1.0; pointer-events: none; z-index: 1; }

        /* CYBERPUNK TERMINAL OVERLAY */
        #terminalOverlay { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 20; background: rgba(2, 2, 4, 0.7); pointer-events: none; display: none; }
        .terminal-status-box { background: rgba(10, 15, 28, 0.95); border: 2px solid #00ff66; box-shadow: 0 0 30px rgba(0, 255, 102, 0.4), inset 0 0 15px rgba(0, 255, 102, 0.2); padding: 40px 60px; text-align: center; border-radius: 12px; min-width: 460px; position: relative; }
        .access-text { font-family: monospace; font-size: 3rem; font-weight: bold; letter-spacing: 4px; color: #ffffff; text-shadow: 0 0 15px #00ff66, 0 0 30px rgba(0, 255, 102, 0.6); margin-bottom: 12px; display: none; animation: neonBreathing 2s ease-in-out infinite; }
        .sub-status { font-family: monospace; color: #a3a8b3; font-size: 14px; margin-bottom: 25px; }
        .cyber-progress-bg { width: 100%; height: 16px; background: #111625; border: 1px solid rgba(0, 255, 102, 0.3); border-radius: 6px; overflow: hidden; }
        .cyber-progress-bar { height: 100%; width: 0%; background: #00ff66; box-shadow: 0 0 15px #00ff66; transition: width 0.1s linear; }
        .terminal-logs { font-family: monospace; color: #00ff66; font-size: 11px; text-align: left; margin-top: 25px; max-height: 80px; overflow: hidden; opacity: 0.85; line-height: 1.6; }
        @keyframes neonBreathing { 0%, 100% { opacity: 1; text-shadow: 0 0 15px #00ff66, 0 0 30px #00ff66; } 50% { opacity: 0.8; text-shadow: 0 0 8px #00ff66, 0 0 15px #00ff66; } }

        /* CRYSTAL CLEAR TRANSPARENT PANELS */
        .left-side { flex: 1.2; background: linear-gradient(135deg, rgba(8, 12, 24, 0.4) 0%, rgba(4, 6, 12, 0.5) 100%); display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 40px; position: relative; border-right: 1px solid rgba(0, 255, 102, 0.15); z-index: 5; }
        .banner-content { text-align: center; z-index: 2; max-width: 520px; }
        .banner-content h1 { font-size: 3.5rem; color: #1a73e8; margin-bottom: 25px; letter-spacing: 2px; font-weight: 900; }
        .banner-content h1 span { color: #00ff66; text-shadow: 0 0 15px rgba(0, 255, 102, 0.4); }
        .banner-content h2 { font-size: 1.9rem; color: #ffffff; margin-bottom: 15px; font-weight: 800; line-height: 1.3; }
        .banner-content p { color: #e2e8f0; font-size: 1.05rem; line-height: 1.6; margin-bottom: 30px; text-shadow: 0 2px 4px rgba(0,0,0,0.9); }
        .features-badges { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        .badge { background: rgba(2, 2, 4, 0.75); border: 1px solid rgba(26, 115, 232, 0.4); padding: 8px 18px; border-radius: 20px; font-size: 13px; font-weight: 600; color: #ffffff; }
        .badge.green { border-color: rgba(0, 255, 102, 0.6); color: #00ff66; box-shadow: 0 0 10px rgba(0, 255, 102, 0.3); }

        .right-side { flex: 1; background-color: rgba(6, 10, 18, 0.4); display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 40px; z-index: 5; }

        /* 🆕 DYNAMIC SWITCHABLE BOX FOR AUTH & ENROLLMENT */
        .card-container { width: 100%; max-width: 400px; background: rgba(10, 15, 28, 0.85); border: 1px solid rgba(26, 115, 232, 0.3); border-radius: 12px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .auth-form { display: none; }
        .auth-form.active { display: block; }
        .auth-container h2 { font-size: 1.8rem; margin-bottom: 6px; color: #ffffff; }
        .auth-container p.subtitle { color: #cbd5e1; font-size: 13px; margin-bottom: 20px; }
        .input-group { margin-bottom: 16px; }
        .input-group label { display: block; font-size: 13px; color: #cbd5e1; margin-bottom: 6px; }
        .input-group input { width: 100%; padding: 11px 14px; background: rgba(15, 22, 38, 0.9); border: 1px solid rgba(26, 115, 232, 0.4); border-radius: 8px; color: #ffffff; font-size: 14px; transition: all 0.3s ease; }
        .input-group input:focus { outline: none; border-color: #00ff66; box-shadow: 0 0 12px rgba(0, 255, 102, 0.4); }
        .form-footer-links { display: flex; justify-content: space-between; align-items: center; font-size: 13px; margin-bottom: 20px; }
        .forgot-pass { color: #38bdf8; text-decoration: none; }
        .forgot-pass:hover { text-decoration: underline; }
        .submit-btn { width: 100%; padding: 13px; background: #1a73e8; color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; }
        .submit-btn:hover { background: #155cb8; box-shadow: 0 0 20px rgba(26, 115, 232, 0.5); }
        .switch-prompt { text-align: center; font-size: 13px; color: #cbd5e1; margin-top: 20px; }
        .switch-prompt a { color: #00ff66; text-decoration: none; font-weight: 600; }
        .switch-prompt a:hover { text-decoration: underline; }

        /* 🆕 NEW COURSE ENROLLMENT TILE & THUMBNAIL */
        #enrollmentForm.active { display: flex; flex-direction: column; align-items: center; }
        .course-enroll-card { display: flex; flex-direction: column; align-items: center; width: 100%; background: #0f1626; border-radius: 12px; padding: 25px; border: 1px solid rgba(0, 255, 102, 0.2); box-shadow: inset 0 0 10px rgba(0, 255, 102, 0.1); }
        .course-enroll-card h2 { font-size: 1.4rem; color: #00ff66; margin-bottom: 8px; font-weight: 700; }
        .course-enroll-card p.subtitle { font-size: 12px; color: #a3a8b3; text-align: center; margin-bottom: 25px; }

        /* 🟩 GAEL VAROQUAUX-INSPIRED ANIMATED THUMBNAIL */
        .thumbnail-box { position: relative; width: 100%; height: 180px; background: #020204; border-radius: 8px; overflow: hidden; border: 2px solid rgba(26, 115, 232, 0.3); margin-bottom: 25px; }
        #courseCanvas { width: 100%; height: 100%; }

        .form-action-btn { width: 100%; padding: 13px; background: #00ff66; color: #020204; border: none; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.3s ease; letter-spacing: 0.5px; box-shadow: 0 0 15px rgba(0, 255, 102, 0.4); }
        .form-action-btn:hover { background: #00cc52; box-shadow: 0 0 25px rgba(0, 255, 102, 0.6); }

        @media (max-width: 768px) { body { flex-direction: column; } .left-side { display: none; } .right-side { padding: 20px; } .terminal-status-box { min-width: 90%; padding: 20px; } }
    </style>
</head>
<body>

    <canvas id="coderRain"></canvas>

    <div id="terminalOverlay">
        <div class="terminal-status-box">
            <div id="accessText" class="access-text">ACCESS GRANTED</div>
            <div id="statusSub" class="sub-status">INITIALIZING SYSTEM_CRACK...</div>
            <div class="cyber-progress-bg">
                <div id="progressBar" class="cyber-progress-bar"></div>
            </div>
            <div id="logBox" class="terminal-logs"></div>
        </div>
    </div>

    <div class="left-side">
        <div class="banner-content">
            <h1>PROGRAM<span>10X</span></h1>
            <h2>One Portal. Infinite Tech.<br>Master Coding to <span style="color: #00ff66; text-shadow: 0 0 15px #00ff66;">Next-Gen AI</span>.</h2>
            <p>Stop jumping from channel to channel. From building your core logic to deploying your own AI agents, master every language the modern industry demands.</p>
            <div class="features-badges">
                <span class="badge">🚀 Full-Stack Tech</span>
                <span class="badge">🧠 AI & Automation</span>
                <span class="badge green">⚡ Placement Ready</span>
            </div>
        </div>
    </div>

    <div class="right-side">
        <div class="card-container auth-container">
            
            <div id="enrollmentForm" class="auth-form active">
                <div class="course-enroll-card">
                    <h2>Math Magic with AI</h2>
                    <p class="subtitle">Quantum Equations & Logic Streams: Unlock the Algorithms of Next-Gen Tech.</p>
                    
                    <div class="thumbnail-box">
                        <canvas id="courseCanvas"></canvas>
                    </div>

                    <button class="form-action-btn" onclick="startEnrollmentAnimation()">ENROLL NOW</button>
                    <p class="switch-prompt">Need help? Ask <a href="#" onclick="alert('Prof. Ami: Hello, I am your 10X assistant. This course will master AI Mathematics. Enroll to begin.')">Prof. Ami (AI)</a></p>
                }
            </div>

            <div id="loginForm" class="auth-form">
                <h2>Student Login</h2>
                <p class="subtitle">Enter your credentials to access your dashboard</p>
                <form onsubmit="startCyberAnimation(event, 'login')">
                    <div class="input-group">
                        <label for="loginEmail">Email Address</label>
                        <input type="email" id="loginEmail" placeholder="anon@program10x.com" required>
                    </div>
                    <div class="input-group">
                        <label for="loginPassword">Password</label>
                        <input type="password" id="loginPassword" placeholder="Minimum 6 characters" required>
                    </div>
                    <div class="form-footer-links">
                        <a href="#" class="forgot-pass">Forgot password?</a>
                    </div>
                    <button type="submit" class="submit-btn">Unlock Portal</button>
                </form>
                <p class="switch-prompt">Professor said to enroll in a new core class first.</p>
            </div>

        </div>
    </div>

    <script>
        // Matrix Falling Rain Logic
        const canvas = document.getElementById('coderRain');
        const ctx = canvas.getContext('2d');
        function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        const alphabet = "010101010101010101010101ABCDEFGHIJKLMNOPQRSTUVWXYZ<>[]{}/_=+X%#$@";
        const fontSize = 12; const columns = canvas.width / fontSize;
        const rainDrops = Array(Math.floor(columns)).fill(1);
        for (let x = 0; x < columns; x++) { rainDrops[x] = Math.random() * -100; }

        function drawMatrix() {
            ctx.fillStyle = 'rgba(2, 2, 4, 0.05)'; ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#00ff66'; ctx.font = 'bold ' + fontSize + 'px monospace'; ctx.shadowBlur = 6; ctx.shadowColor = '#00ff66';
            for (let i = 0; i < rainDrops.length; i++) {
                const text = alphabet.charAt(Math.floor(Math.random() * alphabet.length));
                ctx.fillText(text, i * fontSize, rainDrops[i] * fontSize);
                if (rainDrops[i] * fontSize > canvas.height && Math.random() > 0.985) { rainDrops[i] = 0; }
                rainDrops[i]++;
            }
            ctx.shadowBlur = 0; 
        }
        setInterval(drawMatrix, 28); 

        // 🟩 COURSE CANVAS ANIMATION: MATH MAGIC WITH AI (GAEL VAROQUAUX STYLE)
        const courseCanvas = document.getElementById('courseCanvas');
        const cCtx = courseCanvas.getContext('2d');
        const mathParticles = [];

        function initCourseCanvas() {
            courseCanvas.width = courseCanvas.parentElement.clientWidth;
            courseCanvas.height = courseCanvas.parentElement.clientHeight;
            for(let i=0; i<80; i++) {
                mathParticles.push({
                    x: Math.random() * courseCanvas.width,
                    y: Math.random() * courseCanvas.height,
                    vx: (Math.random() - 0.5) * 1.5,
                    vy: (Math.random() - 0.5) * 1.5,
                    size: Math.random() * 2.5,
                    hue: Math.random() > 0.8 ? 130 : 210 // Green and Blue
                });
            }
        }
        initCourseCanvas();
        window.addEventListener('resize', initCourseCanvas);

        const complexFormulas = [
            '∑ (2ⁿ / n!)',
            '∇ · J = - ∂ρ/∂t',
            '∫ e^(-x²) dx',
            'E = mc²',
            'z = σ(Wx + b)'
        ];

        function drawCourseThumbnail() {
            cCtx.fillStyle = '#010411'; // Elite deep dark blue
            cCtx.fillRect(0, 0, courseCanvas.width, courseCanvas.height);

            // Animated Quantum Field Particles
            cCtx.shadowBlur = 10;
            mathParticles.forEach(p => {
                cCtx.fillStyle = `hsla(${p.hue}, 90%, 65%, 0.85)`;
                cCtx.beginPath();
                cCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                cCtx.fill();
                p.x += p.vx; p.y += p.vy;
                if(p.x<0 || p.x>courseCanvas.width) p.vx *= -1;
                if(p.y<0 || p.y>courseCanvas.height) p.vy *= -1;
            });

            // Glowing complex equations
            cCtx.fillStyle = 'rgba(255, 255, 255, 0.9)';
            cCtx.font = 'bold 16px Courier New, monospace';
            cCtx.shadowColor = 'rgba(26, 115, 232, 1)';
            cCtx.shadowBlur = 20;
            complexFormulas.forEach((f, i) => {
                cCtx.fillText(f, 25 + i*70, 45 + i*25);
            });

            // "MATH MAGIC" - Animated text effect
            cCtx.fillStyle = '#ffffff';
            cCtx.font = 'bold 24px Segoe UI, Tahoma';
            cCtx.shadowColor = 'rgba(0, 255, 102, 1)';
            cCtx.shadowBlur = 20;
            const textY = 120 + Math.sin(Date.now()*0.005) * 5;
            cCtx.fillText("MATH MAGIC", 10, textY);
            
            cCtx.fillStyle = '#1a73e8';
            cCtx.font = '700 18px Segoe UI, Tahoma';
            cCtx.shadowColor = 'rgba(26, 115, 232, 0.8)';
            cCtx.fillText("with AI", 160, textY+5);

            cCtx.shadowBlur = 0;
            requestAnimationFrame(drawCourseThumbnail);
        }
        drawCourseThumbnail();

        // enrollment specific animation
        function startEnrollmentAnimation() {
            const overlay = document.getElementById('terminalOverlay');
            const pBar = document.getElementById('progressBar');
            const statusSub = document.getElementById('statusSub');
            const logBox = document.getElementById('logBox');
            overlay.style.display = 'flex'; pBar.style.width = '0%'; document.getElementById('accessText').style.display = 'none'; logBox.innerHTML = "";
            statusSub.innerText = "INITIATING QuantumMath_Enrollment v1.4...";
            
            const logs = [
                "[OK] Linking course node: MATH_MAGIC_AI...",
                "[INFO] Opening system enrollment pipeline...",
                "[OK] Creating security hash for Anon...",
                "[SUCCESS] Token match confirmed.",
                "[SYS] Directing student to dashboard asset loader..."
            ];
            
            let progress = 0;
            const interval = setInterval(() => {
                progress += 5;
                if(progress >= 100) {
                    clearInterval(interval); pBar.style.width = '100%'; statusSub.innerText = "Quantum Math Enrollment Complete!";
                    document.getElementById('accessText').innerText = "ENROLLED";
                    document.getElementById('accessText').style.display = 'block';
                    setTimeout(() => {
                        overlay.style.display = 'none';
                        showLoginForm();
                    }, 1500);
                } else {
                    pBar.style.width = progress + '%';
                    if(progress % 20 === 0) {
                        logBox.innerHTML += `<div>${logs[Math.floor(progress/20)-1]}</div>`;
                        logBox.scrollTop = logBox.scrollHeight;
                    }
                }
            }, 60);
        }

        // Standard Switch Logic
        function showLoginForm() {
            document.getElementById('enrollmentForm').classList.remove('active');
            document.getElementById('loginForm').classList.add('active');
        }

        // Standard Cracking Animation for Login
        function startCyberAnimation(e, type) {
            e.preventDefault();
            const overlay = document.getElementById('terminalOverlay');
            const pBar = document.getElementById('progressBar');
            const statusSub = document.getElementById('statusSub');
            const logBox = document.getElementById('logBox');
            overlay.style.display = 'flex'; pBar.style.width = '0%'; document.getElementById('accessText').style.display = 'none'; logBox.innerHTML = "";
            
            statusSub.innerText = "AUTHENTICATING SECURITY KEYS...";
            
            const logs = [
                "[OK] Connecting to main server nodes...",
                "[INFO] Checking decryption privileges...",
                "[OK] Running payload injection...",
                "[SUCCESS] Token match confirmed.",
                "[SYS] Fetching 10X developer dashboard assets..."
            ];
            
            let progress = 0;
            const interval = setInterval(() => {
                progress += 5;
                if(progress >= 100) {
                    clearInterval(interval); pBar.style.width = '100%'; statusSub.innerText = "ADMIN PRIVILEGES: TRUE";
                    document.getElementById('accessText').style.display = 'block';
                    setTimeout(() => { alert("Access Approved! Redirecting Anon to P10X Space..."); overlay.style.display = 'none'; }, 1500);
                } else {
                    pBar.style.width = progress + '%';
                    if(progress % 20 === 0) {
                        logBox.innerHTML += `<div>${logs[Math.floor(progress/20)-1]}</div>`;
                        logBox.scrollTop = logBox.scrollHeight;
                    }
                }
            }, 60);
        }
    </script>
</body>
</html>
