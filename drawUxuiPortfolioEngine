<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Program10X | Advanced Student Dashboard</title>
    <!-- Google Fonts for High-Tech Aesthetic -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        /* --- 🎨 SYSTEM VARIABLES & THEME --- */
        :root {
            --bg-deep: #030712;
            --bg-card: rgba(15, 23, 42, 0.7);
            --bg-card-hover: #111c44;
            --text-primary: #f3f4f6;
            --text-muted: #9ca3af;
            --neon-blue: #38bdf8;
            --neon-green: #00ffcc;
            --neon-glow: 0 0 15px rgba(56, 189, 248, 0.4);
            --border-glow: rgba(255, 255, 255, 0.1);
            --sidebar-width: 260px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-primary);
            overflow-x: hidden;
            display: flex;
        }

        /* --- 📁 SIDEBAR NAVIGATION SYSTEM --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(180deg, #070a1e 0%, #030712 100%);
            border-right: 1px solid rgba(56, 189, 248, 0.15);
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 2rem 1.5rem;
            z-index: 100;
        }

        .brand {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: 2px;
            margin-bottom: 3rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .brand span {
            color: var(--neon-blue);
            text-shadow: var(--neon-glow);
        }

        .nav-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            padding: 0.8rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .nav-item.active a, .nav-item a:hover {
            color: var(--text-primary);
            background: rgba(56, 189, 248, 0.08);
            border-left: 3px solid var(--neon-blue);
        }

        /* --- 💻 MAIN DASHBOARD LAYOUT --- */
        .main-content {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
            padding: 2.5rem;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 1.5rem;
        }

        .welcome-box h1 {
            font-size: 2.2rem;
            font-weight: 700;
        }

        .welcome-box p {
            color: var(--text-muted);
            margin-top: 0.3rem;
        }

        /* --- 🗂️ GRID ARCHITECTURE --- */
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        .course-card {
            background: var(--bg-card);
            border: 1px solid var(--border-glow);
            border-radius: 18px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: 0.3s;
        }

        .course-card:hover {
            transform: translateY(-8px);
            border-color: #00ff66;
            box-shadow: 0 10px 30px rgba(0, 255, 102, 0.15);
        }

        .card-img-canvas-box {
            height: 140px;
            width: 100%;
            position: relative;
            background: #01040a;
            border-bottom: 1px solid rgba(26, 115, 232, 0.15);
            overflow: hidden;
            cursor: pointer;
        }

        .card-img-canvas-box canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .card-body {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .tech-badge {
            display: inline-block;
            align-self: flex-start;
            background: rgba(56, 189, 248, 0.08);
            border: 1px solid rgba(56, 189, 248, 0.2);
            color: var(--neon-blue);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
        }

        .tracker-box {
            margin-top: auto;
            margin-bottom: 1.5rem;
        }

        .tracker-text {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
        }

        .tracker-bg {
            width: 100%;
            height: 6px;
            background-color: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            overflow: hidden;
        }

        .tracker-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--neon-blue), var(--neon-green));
            border-radius: 10px;
        }

        .btn-view {
            display: block;
            width: 100%;
            text-align: center;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 600;
            padding: 0.8rem;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .course-card:hover .btn-view {
            background: #00ff66;
            color: #000;
            font-weight: 700;
        }
    </style>
</head>
<body>

    <!-- 📁 SIDEBAR NAVIGATION SYSTEM -->
    <nav class="sidebar">
        <div class="brand">PROG<span>10X</span></div>
        <ul class="nav-links">
            <li class="nav-item active"><a href="#">Dashboard</a></li>
            <li class="nav-item"><a href="#">Core Modules</a></li>
            <li class="nav-item"><a href="#">AI Labs</a></li>
            <li class="nav-item"><a href="#">Settings</a></li>
        </ul>
    </nav>

    <!-- 💻 MAIN DASHBOARD LAYOUT -->
    <main class="main-content">
        <header>
            <div class="welcome-box">
                <h1>Welcome, Developer S</h1>
                <p>Neural dashboard status optimal.</p>
            </div>
        </header>

        <!-- 🗂️ GRID ARCHITECTURE & CARDS -->
        <div class="courses-grid">
            
            <!-- Card 1 -->
            <div class="course-card">
                <div class="card-img-canvas-box" id="mathWrapper">
                    <canvas id="discreteMathCanvas"></canvas>
                </div>
                <div class="card-body">
                    <div class="card-title">Math Magic with AI</div>
                    <div class="tech-badge">LOGIC ENGINE V1.0</div>
                    <div class="tracker-box">
                        <div class="tracker-text"><span>PROGRESS</span><span>100%</span></div>
                        <div class="tracker-bg"><div class="tracker-fill" style="width: 100%;"></div></div>
                    </div>
                    <a href="#" class="btn-view">OPEN MODULE</a>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="course-card">
                <div class="card-img-canvas-box" id="voiceWrapper">
                    <canvas id="voiceSynthCanvas"></canvas>
                </div>
                <div class="card-body">
                    <div class="card-title">English Mouth Driven with AI</div>
                    <div class="tech-badge">VOICE SYNTHESIS</div>
                    <div class="tracker-box">
                        <div class="tracker-text"><span>PROGRESS</span><span>98%</span></div>
                        <div class="tracker-bg"><div class="tracker-fill" style="width: 98%;"></div></div>
                    </div>
                    <a href="#" class="btn-view">OPEN MODULE</a>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="course-card">
                <div class="card-img-canvas-box" id="aiWrapper">
                    <canvas id="aiNeuralCanvas"></canvas>
                </div>
                <div class="card-body">
                    <div class="card-title">Artificial Intelligence</div>
                    <div class="tech-badge">NEURAL NETWORKS</div>
                    <div class="tracker-box">
                        <div class="tracker-text"><span>PROGRESS</span><span>100%</span></div>
                        <div class="tracker-bg"><div class="tracker-fill" style="width: 100%;"></div></div>
                    </div>
                    <a href="#" class="btn-view">OPEN MODULE</a>
                </div>
            </div>

            <!-- Card 4 (Upgraded Premium Layout from Mockup) -->
            <div class="course-card">
                <div class="card-img-canvas-box" id="uxuiWrapper">
                    <canvas id="uxuiInterfaceCanvas"></canvas>
                </div>
                <div class="card-body">
                    <div class="card-title">UX/UI Design with Cloud AI ML</div>
                    <div class="tech-badge">Interface Analytics</div>
                    <div class="tracker-box">
                        <div class="tracker-text"><span>PROGRESS</span><span>85%</span></div>
                        <div class="tracker-bg"><div class="tracker-fill" style="width: 85%;"></div></div>
                    </div>
                    <a href="#" class="btn-view">OPEN MODULE</a>
                </div>
            </div>

        </div>
    </main>

    <!-- ⚡ HIGH PERFORMANCE ENGINES -->
    <script>
        // --- Card 1 Engine ---
        const mathCanvas = document.getElementById('discreteMathCanvas');
        const mCtx = mathCanvas.getContext('2d');
        const mathWrapper = document.getElementById('mathWrapper');
        let nodes = [];
        function setupMathCanvas() {
            mathCanvas.width = mathWrapper.clientWidth || 300;
            mathCanvas.height = mathWrapper.clientHeight || 140;
        }
        setupMathCanvas();
        for (let i = 0; i < 15; i++) {
            nodes.push({ x: Math.random() * 300, y: Math.random() * 140, vx: (Math.random() - 0.5) * 0.5, vy: (Math.random() - 0.5) * 0.5 });
        }
        function drawMindPalace() {
            mCtx.fillStyle = '#01040a'; mCtx.fillRect(0, 0, mathCanvas.width, mathCanvas.height);
            mCtx.fillStyle = '#00ff66'; mCtx.strokeStyle = 'rgba(0, 255, 102, 0.15)';
            nodes.forEach(n => {
                n.x += n.vx; n.y += n.vy;
                if(n.x < 0 || n.x > mathCanvas.width) n.vx *= -1;
                if(n.y < 0 || n.y > mathCanvas.height) n.vy *= -1;
                mCtx.beginPath(); mCtx.arc(n.x, n.y, 2, 0, Math.PI*2); mCtx.fill();
            });
            requestAnimationFrame(drawMindPalace);
        }

        // --- Card 2 Engine ---
        const voiceCanvas = document.getElementById('voiceSynthCanvas');
        const vCtx = voiceCanvas.getContext('2d');
        const voiceWrapper = document.getElementById('voiceWrapper');
        function setupVoiceCanvas() {
            voiceCanvas.width = voiceWrapper.clientWidth || 300;
            voiceCanvas.height = voiceWrapper.clientHeight || 140;
        }
        setupVoiceCanvas();
        let vAudioOffset = 0;
        function drawVoiceSynthEngine() {
            vCtx.fillStyle = '#01040a'; vCtx.fillRect(0, 0, voiceCanvas.width, voiceCanvas.height);
            vAudioOffset += 0.05;
            vCtx.strokeStyle = '#38bdf8'; vCtx.lineWidth = 1.5;
            vCtx.beginPath();
            for(let i=0; i<voiceCanvas.width; i++) {
                let y = voiceCanvas.height/2 + Math.sin(i*0.03 + vAudioOffset) * 20 * Math.sin(i*0.01);
                if(i===0) vCtx.moveTo(i, y); else vCtx.lineTo(i, y);
            }
            vCtx.stroke();
            requestAnimationFrame(drawVoiceSynthEngine);
        }

        // --- Card 3 Engine ---
        const aiCanvas = document.getElementById('aiNeuralCanvas');
        const aiCtx = aiCanvas.getContext('2d');
        const aiWrapper = document.getElementById('aiWrapper');
        function setupAiCanvas() {
            aiCanvas.width = aiWrapper.clientWidth || 300;
            aiCanvas.height = aiWrapper.clientHeight || 140;
        }
        setupAiCanvas();
        let aiNodes = [];
        for(let i=0; i<4; i++) {
            for(let j=0; j<4; j++) aiNodes.push({x: 50 + i*60, y: 25 + j*30});
        }
        function drawAiNeuralEngine() {
            aiCtx.fillStyle = '#01040a'; aiCtx.fillRect(0, 0, aiCanvas.width, aiCanvas.height);
            aiCtx.strokeStyle = 'rgba(56, 189, 248, 0.1)'; aiCtx.lineWidth = 0.5;
            aiNodes.forEach((n, idx) => {
                aiNodes.forEach((t, tIdx) => {
                    if(t.x > n.x && t.x - n.x < 70) {
                        aiCtx.beginPath(); aiCtx.moveTo(n.x, n.y); aiCtx.lineTo(t.x, t.y); aiCtx.stroke();
                    }
                });
                aiCtx.fillStyle = '#38bdf8'; aiCtx.beginPath(); aiCtx.arc(n.x, n.y, 2.5, 0, Math.PI*2); aiCtx.fill();
            });
            requestAnimationFrame(drawAiNeuralEngine);
        }

        // --- Card 4 Engine (Premium Layout Replica) ---
        const uxuiCanvas = document.getElementById('uxuiInterfaceCanvas');
        const uxCtx = uxuiCanvas.getContext('2d');
        const uxuiWrapper = document.getElementById('uxuiWrapper');
        let uxMouse = { x: null, y: null, active: false };

        function setupUxuiCanvas() {
            uxuiCanvas.width = uxuiWrapper.clientWidth || 300;
            uxuiCanvas.height = uxuiWrapper.clientHeight || 140;
        }
        setupUxuiCanvas();

        uxuiWrapper.addEventListener('mousemove', (e) => {
            const rect = uxuiCanvas.getBoundingClientRect();
            uxMouse.x = e.clientX - rect.left; uxMouse.y = e.clientY - rect.top; uxMouse.active = true;
        });
        uxuiWrapper.addEventListener('mouseleave', () => { uxMouse.active = false; });

        function drawUxuiPortfolioEngine() {
            uxCtx.fillStyle = '#0b0f19'; uxCtx.fillRect(0, 0, uxuiCanvas.width, uxuiCanvas.height);
            let w = uxuiCanvas.width, h = uxuiCanvas.height;
            let time = Date.now() * 0.0015;

            // 1. Tech Grid Background
            uxCtx.strokeStyle = 'rgba(0, 245, 255, 0.03)'; uxCtx.lineWidth = 0.5;
            for(let g = 0; g < w; g += 15) { uxCtx.beginPath(); uxCtx.moveTo(g, 0); uxCtx.lineTo(g, h); uxCtx.stroke(); }

            // 2. Left Side: Mobile UI Wireframe
            let phoneX = 25, phoneY = 15, phoneW = 50, phoneH = 110;
            uxCtx.strokeStyle = 'rgba(56, 189, 248, 0.3)'; uxCtx.lineWidth = 1.5;
            uxCtx.strokeRect(phoneX, phoneY, phoneW, phoneH);
            uxCtx.fillStyle = 'rgba(0, 245, 255, 0.08)'; uxCtx.fillRect(phoneX + 5, phoneY + 25, phoneW - 10, 30);
            uxCtx.fillStyle = 'rgba(236, 72, 153, 0.4)'; uxCtx.fillRect(phoneX + 8, phoneY + 65, 12, 6);
            uxCtx.fillStyle = 'rgba(56, 189, 248, 0.4)'; uxCtx.fillRect(phoneX + 25, phoneY + 65, 18, 6);

            // 3. Center: Main Core UI/UX Interactive Hub
            let cx = w / 2 + 5, cy = h / 2;
            uxCtx.strokeStyle = 'rgba(236, 72, 153, 0.25)'; uxCtx.setLineDash([4, 4]);
            uxCtx.beginPath(); uxCtx.arc(cx, cy, 30, time, time + Math.PI * 1.5); uxCtx.stroke();
            uxCtx.setLineDash([]);
            uxCtx.strokeStyle = 'rgba(0, 245, 255, 0.4)';
            uxCtx.beginPath(); uxCtx.arc(cx, cy, 22 + Math.sin(time*2)*2, 0, Math.PI * 2); uxCtx.stroke();

            uxCtx.font = '900 12px "Orbitron", sans-serif'; uxCtx.fillStyle = '#00f5ff';
            uxCtx.fillText("UI", cx - 20, cy + 4);
            uxCtx.fillStyle = '#ec4899'; uxCtx.fillText("UX", cx + 4, cy + 4);

            // 4. Right Side: Floating Glass Dashboard Analytics Panel
            let dashX = w - 80, dashY = 20, dashW = 60, dashH = 95;
            uxCtx.strokeStyle = 'rgba(0, 245, 255, 0.2)'; uxCtx.strokeRect(dashX, dashY, dashW, dashH);
            uxCtx.strokeStyle = '#ec4899'; uxCtx.lineWidth = 2;
            uxCtx.beginPath(); uxCtx.arc(dashX + 18, dashY + 28, 8, -Math.PI/2, Math.PI * 0.7); uxCtx.stroke();

            let eqBars = [10, 22, 15, 28];
            eqBars.forEach((val, i) => {
                let dynamicH = val + Math.sin(time * 3 + i) * 4;
                if (uxMouse.active) dynamicH += 3;
                uxCtx.fillStyle = '#00f5ff';
                uxCtx.fillRect(dashX + 6 + (i * 12), dashY + 85 - dynamicH, 6, dynamicH);
            });

            // 5. Interactive Laser Scanning Target
            if (uxMouse.active) {
                uxCtx.strokeStyle = 'rgba(236, 72, 153, 0.2)'; uxCtx.lineWidth = 0.5;
                uxCtx.beginPath(); uxCtx.moveTo(0, uxMouse.y); uxCtx.lineTo(w, uxMouse.y); uxCtx.stroke();
                uxCtx.beginPath(); uxCtx.moveTo(uxMouse.x, 0); uxCtx.lineTo(uxMouse.x, h); uxCtx.stroke();
            }
            requestAnimationFrame(drawUxuiPortfolioEngine);
        }

        // --- 🚀 INITIALIZE SYSTEM ENGINES ---
        setTimeout(() => {
            setupMathCanvas(); setupVoiceCanvas(); setupAiCanvas(); setupUxuiCanvas();
            drawMindPalace(); drawVoiceSynthEngine(); drawAiNeuralEngine(); drawUxuiPortfolioEngine();
        }, 150);

        window.addEventListener('resize', () => {
            setupMathCanvas(); setupVoiceCanvas(); setupAiCanvas(); setupUxuiCanvas();
        });
    </script>
</body>
</html>
